#!/usr/bin/env bash
# Submit with: sbatch deploy/slurm.sbatch.example
#
# Assumed layout:
#   parent/
#     down_obeservation/
#     data/

#SBATCH --job-name=gdex_download
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=2
#SBATCH --time=12:00:00
#SBATCH --output=../data/_logs/slurm-%j.out
#SBATCH --error=../data/_logs/slurm-%j.err

set -euo pipefail

cd "${SLURM_SUBMIT_DIR:?submit this job from the repository root}"
mkdir -p ../data/_logs

module load python/3.10 2>/dev/null || true

export GDEX_YEAR=2026
export GDEX_MAX_WORKERS=2

bash scripts/run_daily.sh
