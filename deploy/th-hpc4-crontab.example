# Install from the login node with:
#   crontab deploy/th-hpc4-crontab.example
#
# Assumed layout:
#   $HOME/down_obeservation/
#   $HOME/data/
#
# Legacy compute-node version. Prefer th-hpc4-login-crontab.example when compute
# nodes cannot access the external network.

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin

0 0 * * * cd "$HOME/down_obeservation" && mkdir -p ../data/_logs && (squeue -u "$USER" -h -n gdex_download_loop | grep -q . || yhbatch deploy/th-hpc4-gdex-download.sub.example) >> ../data/_logs/yhbatch-submit.log 2>&1
