# Copy to ~/.config/gdex-observation-download.env only if you need to override
# defaults. By default, scripts/run_daily.sh writes data to a sibling directory:
#
#   parent/
#     down_obeservation/
#     data/

# Repository checkout path. The install script fills the systemd unit with this path.
# APP_DIR=/opt/down_obeservation

# Keep data outside the git checkout on production servers. If the repository is
# /work/USER/down_obeservation, these defaults become /work/USER/data,
# /work/USER/data/_state, and /work/USER/data/_logs.
# DATA_DIR=/work/USER/data
# GDEX_DATA_ROOT=/work/USER/data
# GDEX_STATE_DIR=/work/USER/data/_state
# GDEX_LOG_DIR=/work/USER/data/_logs

# Requested target year.
GDEX_YEAR=2026

# UCAR recommends avoiding aggressive parallel downloads. Keep this below 10.
GDEX_MAX_WORKERS=2
GDEX_MAX_DEPTH=8
GDEX_MAX_PAGES=20000

# Optional Python interpreter.
# PYTHON_BIN=/usr/bin/python3
